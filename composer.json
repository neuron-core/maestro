{
    "name": "neuron-core/maestro",
    "description": "AI Coding Assistant built entirely in PHP with Neuron AI framework",
    "type": "library",
    "keywords": [
        "ai",
        "coding",
        "assistant",
        "symfony",
        "cli",
        "neuron-ai"
    ],
    "homepage": "https://github.com/neuron-core/maestro",
    "license": "FSL-1.1-MIT",
    "authors": [
        {
            "name": "Valerio Barbera",
            "email": "valerio@inspector.dev"
        }
    ],
    "support": {
        "issues": "https://github.com/neuron-core/maestro/issues",
        "source": "https://github.com/neuron-core/maestro"
    },
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "neuron-core/neuron-ai": "^3.0",
        "symfony/console": "^8.0",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.0",
        "rector/rector": "^2.0",
        "tomasvotruba/type-coverage": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "NeuronCore\\Maestro\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NeuronCore\\Maestro\\Tests\\": "tests/"
        }
    },
    "scripts-descriptions": {
        "maestro discover": "Discover Maestro extensions from installed Composer packages"
    },
    "extra": {
        "maestro": {
            "extensions": [
                "NeuronCore\\Maestro\\Extension\\Core\\CoreExtension",
                "NeuronCore\\Maestro\\Extension\\Coding\\CodingExtension"
            ]
        }
    },
    "bin": [
        "bin/maestro"
    ],
    "scripts": {
        "analyse": [
            "vendor/bin/phpstan analyse --memory-limit=1G -v"
        ],
        "format": [
            "@refactor",
            "@style"
        ],
        "style": [
            "php-cs-fixer fix --allow-risky=yes"
        ],
        "refactor": [
            "vendor/bin/rector"
        ],
        "test": [
            "vendor/bin/phpunit --colors=always"
        ],
        "maestro discover": "php bin/maestro discover",
        "post-autoload-dump": "php bin/maestro discover"
    }
}
