#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Maestro - CLI Entry Point
 *
 * AI-powered coding assistant built with Neuron AI framework.
 */

if (php_sapi_name() !== 'cli') {
    exit;
}

// Find autoloader
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../../../../autoload.php',
];

foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require_once $autoloadPath;
        break;
    }
}

use NeuronCore\Maestro\Commands\DiscoverCommand;
use NeuronCore\Maestro\Commands\InitCommand;
use NeuronCore\Maestro\Commands\MaestroCommand;
use Symfony\Component\Console\Application;

$app = new Application('Maestro', '1.x');
$app->addCommand(new DiscoverCommand());
$app->addCommand(new InitCommand());
$app->addCommand(new MaestroCommand());
$app->setDefaultCommand('maestro');
$app->run();
