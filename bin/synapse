#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Coding Agent - CLI Entry Point
 *
 * AI-powered coding assistant built with Neuron AI framework and Minicli.
 *
 * Usage:
 *   synapse              - Start interactive chat mode
 */

if (php_sapi_name() !== 'cli') {
    exit;
}

// Find autoloader
$autoloadPaths = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
    __DIR__ . '/../../../../autoload.php',
];

foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require_once $autoloadPath;
        break;
    }
}

use Minicli\App;

// Always default to chat mode
$argv[] = 'chat';

$app = new App([
    'app_path' => [
        dirname(__DIR__) . '/src/Command',
    ],
    'theme' => '\Unicorn',
    'debug' => false,
]);

$app->runCommand($argv);
